#!/bin/bash
# ============================================
# 绝区零仪玄角色助手 - 一键部署脚本
# 部署微调模型到 vLLM + OpenCode
# ============================================

set -e

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

print_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
print_success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }
print_warning() { echo -e "${YELLOW}[WARNING]${NC} $1"; }
print_error() { echo -e "${RED}[ERROR]${NC} $1"; }

# ============================================
# 配置（可修改）
# ============================================
MODEL_PATH="${MODEL_PATH:-./models/Qwen/Qwen3-0___6B}"
LORA_PATH="${LORA_PATH:-./output/Qwen3_Yixuan_LoRA_final}"
PORT="${PORT:-8000}"
MODEL_NAME="yixuan-assistant"
VLLM_LOG="vllm.log"

# ============================================
# 步骤 1: 检查环境
# ============================================
print_info "检查环境..."

# 检查是否在项目目录
if [ ! -f "01-Qwen3-Yixuan-LoRA.ipynb" ]; then
    print_error "请在项目根目录运行此脚本"
    exit 1
fi

# 检查模型路径
if [ ! -d "$MODEL_PATH" ]; then
    print_error "模型路径不存在: $MODEL_PATH"
    print_info "请先运行 Notebook 训练模型，或设置 MODEL_PATH 环境变量"
    print_info "例如: MODEL_PATH=./models/Qwen3-0.6B ./yixuan-deploy"
    exit 1
fi

# 检查 LoRA 路径
if [ ! -d "$LORA_PATH" ]; then
    print_error "LoRA 权重不存在: $LORA_PATH"
    print_info "请先运行 Notebook 训练模型，或设置 LORA_PATH 环境变量"
    exit 1
fi

# 检查 vLLM 是否安装
if ! command -v vllm &> /dev/null; then
    print_info "安装 vLLM..."
    pip install -q vllm -i https://mirrors.cloud.tencent.com/pypi/simple/
fi

print_success "环境检查通过"

# ============================================
# 步骤 2: 释放显存（如果有残留进程）
# ============================================
print_info "检查显存占用..."

# 检查是否有占用显存的进程
pkill -f "ipykernel" 2>/dev/null || true
pkill -f "jupyter" 2>/dev/null || true
sleep 2

print_success "显存已释放"

# ============================================
# 步骤 3: 启动 vLLM 服务
# ============================================
print_info "启动 vLLM 服务..."
print_info "  模型路径: $MODEL_PATH"
print_info "  LoRA 路径: $LORA_PATH"
print_info "  端口: $PORT"
print_info "  模型名称: $MODEL_NAME"

# 启动 vLLM（后台运行）
nohup vllm serve "$MODEL_PATH" \
    --port $PORT \
    --model-name $MODEL_NAME \
    --enable-lora \
    --lora-modules yixuan-lora=$LORA_PATH \
    --max-model-len 2048 \
    --gpu-memory-utilization 0.9 \
    --dtype bfloat16 \
    --trust-remote-code \
    --reasoning-parser deepseek_r1 \
    > $VLLM_LOG 2>&1 &

VLLM_PID=$!
print_info "vLLM PID: $VLLM_PID"
print_info "vLLM 日志: $VLLM_LOG"

# ============================================
# 步骤 4: 等待 vLLM 启动
# ============================================
print_info "等待 vLLM 启动（最多 120 秒）..."

for i in $(seq 1 60); do
    if curl -s http://localhost:$PORT/v1/models | grep -q "$MODEL_NAME"; then
        print_success "vLLM 已启动！"
        break
    fi
    if [ $i -eq 60 ]; then
        print_error "vLLM 启动超时"
        print_info "查看日志: tail -50 $VLLM_LOG"
        exit 1
    fi
    sleep 2
    printf "."
done

echo ""
echo "================================================"
print_success "vLLM 服务已就绪！"
echo "================================================"
echo ""
echo -e "${GREEN}API 地址:${NC} http://localhost:$PORT/v1"
echo -e "${GREEN}模型名称:${NC} $MODEL_NAME"
echo ""

# ============================================
# 步骤 5: 配置 OpenCode
# ============================================
print_info "配置 OpenCode..."

mkdir -p ~/.config/opencode

# 备份现有配置
if [ -f ~/.config/opencode/config.json ]; then
    cp ~/.config/opencode/config.json ~/.config/opencode/config.json.bak
fi

cat > ~/.config/opencode/config.json << EOF
{
  "provider": {
    "yixuan-vllm": {
      "name": "Yixuan vLLM",
      "type": "openai-compatible",
      "apiBase": "http://localhost:$PORT/v1",
      "apiKey": "EMPTY",
      "models": {
        "$MODEL_NAME": {
          "name": "$MODEL_NAME",
          "contextWindow": 2048,
          "maxOutputTokens": 512
        }
      }
    }
  },
  "model": "$MODEL_NAME",
  "providerName": "yixuan-vllm"
}
EOF

print_success "OpenCode 配置已写入: ~/.config/opencode/config.json"

# ============================================
# 步骤 6: 创建便捷脚本
# ============================================
print_info "创建便捷脚本..."

# 创建对话脚本
cat > yixuan-chat << 'EOF'
#!/bin/bash
# 与仪玄对话
QUESTION="${1:-你好}"
PORT="${PORT:-8000}"
MODEL_NAME="${MODEL_NAME:-yixuan-assistant}"

echo "问：$QUESTION"
echo "答："
curl -s http://localhost:$PORT/v1/chat/completions \
    -H "Content-Type: application/json" \
    -d "{
        \"model\": \"$MODEL_NAME\",
        \"messages\": [{\"role\": \"user\", \"content\": \"$QUESTION\"}],
        \"max_tokens\": 500
    }" | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    print(data['choices'][0]['message']['content'])
except:
    print('请求失败，请检查 vLLM 服务是否启动')
"
EOF
chmod +x yixuan-chat

# 创建停止脚本
cat > yixuan-stop << 'EOF'
#!/bin/bash
# 停止 vLLM 服务
echo "停止 vLLM 服务..."
pkill -f "vllm serve" 2>/dev/null
echo "已停止"
EOF
chmod +x yixuan-stop

# 把脚本加到 PATH
print_info "将脚本加到系统 PATH..."
for cmd in yixuan-chat yixuan-stop; do
    if [ -w /usr/local/bin ]; then
        ln -sf "$(pwd)/$cmd" /usr/local/bin/$cmd
    else
        sudo ln -sf "$(pwd)/$cmd" /usr/local/bin/$cmd 2>/dev/null || {
            mkdir -p ~/.local/bin
            ln -sf "$(pwd)/$cmd" ~/.local/bin/$cmd
            case ":$PATH:" in
                *":$HOME/.local/bin:"*) ;;
                *) echo 'export PATH="$HOME/.local/bin:$PATH"' >> ~/.bashrc ;;
            esac
        }
    fi
done

print_success "便捷脚本创建完成"

# ============================================
# 完成
# ============================================
echo ""
echo "================================================"
print_success "部署完成！"
echo "================================================"
echo ""
echo -e "${GREEN}使用方式：${NC}"
echo ""
echo "1. 命令行对话："
echo -e "   ${BLUE}yixuan-chat \"你是谁？\"${NC}"
echo ""
echo "2. 启动 OpenCode："
echo -e "   ${BLUE}opencode${NC}"
echo "   然后选择 'yixuan-assistant' 模型"
echo ""
echo "3. 测试 API："
echo -e "   ${BLUE}curl http://localhost:$PORT/v1/models${NC}"
echo ""
echo "4. 停止服务："
echo -e "   ${BLUE}yixuan-stop${NC}"
echo ""
echo -e "${YELLOW}提示：${NC}"
echo "   - vLLM 日志: $VLLM_LOG"
echo "   - 模型名称: $MODEL_NAME"
echo "   - API 地址: http://localhost:$PORT/v1"
echo ""
