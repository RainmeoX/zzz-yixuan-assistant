#!/bin/bash
# ============================================
# 绝区零仪玄角色助手 - 一键部署脚本
# 部署微调模型到 vLLM + OpenCode
# 已验证环境: AMD RX 7900 XTX (gfx1100) + Ubuntu 24.04 + vLLM 0.16
# ============================================

set -e

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

print_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
print_success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }
print_warning() { echo -e "${YELLOW}[WARNING]${NC} $1"; }
print_error() { echo -e "${RED}[ERROR]${NC} $1"; }

# ============================================
# 配置（可修改）
# ============================================
MODEL_PATH="${MODEL_PATH:-./models/Qwen/Qwen3-4B}"
LORA_PATH="${LORA_PATH:-./output/Qwen3_Yixuan_LoRA_final}"
PORT="${PORT:-8000}"
MODEL_NAME="yixuan-assistant"
LORA_NAME="yixuan-lora"
VLLM_LOG="vllm.log"

# ⚠️ AMD RX 7900 XTX (gfx1100) 必须设置此环境变量
export HSA_OVERRIDE_GFX_VERSION=11.0.0

# ============================================
# 步骤 1: 检查环境
# ============================================
print_info "检查环境..."

if [ ! -f "01-Qwen3-Yixuan-LoRA.ipynb" ]; then
    print_error "请在项目根目录运行此脚本"
    exit 1
fi

if [ ! -d "$MODEL_PATH" ]; then
    print_error "模型路径不存在: $MODEL_PATH"
    print_info "请先运行 Notebook 训练模型，或设置 MODEL_PATH 环境变量"
    print_info "例如: MODEL_PATH=./models/Qwen/Qwen3-4B ./yixuan-deploy"
    exit 1
fi

if [ ! -d "$LORA_PATH" ]; then
    print_error "LoRA 权重不存在: $LORA_PATH"
    print_info "请先运行 Notebook 训练模型，或设置 LORA_PATH 环境变量"
    exit 1
fi

if ! command -v vllm &> /dev/null; then
    print_info "安装 vLLM..."
    pip install -q vllm -i https://mirrors.cloud.tencent.com/pypi/simple/
fi

print_success "环境检查通过"

# ============================================
# 步骤 2: 释放显存（如果有残留进程）
# ============================================
print_info "检查显存占用..."
pkill -f "ipykernel" 2>/dev/null || true
pkill -f "jupyter" 2>/dev/null || true
pkill -f "python app.py" 2>/dev/null || true
sleep 2
print_success "显存已释放"

# ============================================
# 步骤 3: 启动 vLLM 服务
# ============================================
print_info "启动 vLLM 服务..."
print_info "  模型路径: $MODEL_PATH"
print_info "  LoRA 路径: $LORA_PATH"
print_info "  端口: $PORT"
print_info "  模型名称: $MODEL_NAME + $LORA_NAME"

# ⚠️ AMD gfx1100 (RX 7900 XTX) 兼容参数
export VLLM_USE_TRITON_FLASH_ATTN=0
export VLLM_USE_ROCM_FLASH_ATTN=1

# vLLM 0.16 验证可用的启动参数
nohup vllm serve "$MODEL_PATH" \
    --port $PORT \
    --served-model-name $MODEL_NAME \
    --enable-lora \
    --lora-modules $LORA_NAME=$LORA_PATH \
    --max-model-len 32768 \
    --gpu-memory-utilization 0.85 \
    --dtype bfloat16 \
    --trust-remote-code \
    --enforce-eager \
    --enable-auto-tool-choice \
    --tool-call-parser hermes \
    --reasoning-parser deepseek_r1 \
    > $VLLM_LOG 2>&1 &

VLLM_PID=$!
print_info "vLLM PID: $VLLM_PID"
print_info "vLLM 日志: $VLLM_LOG"

# ============================================
# 步骤 4: 等待 vLLM 启动
# ============================================
print_info "等待 vLLM 启动（最多 120 秒）..."

for i in $(seq 1 60); do
    if curl -s http://localhost:$PORT/v1/models 2>/dev/null | grep -q "$MODEL_NAME"; then
        print_success "vLLM 已启动！"
        break
    fi
    if [ $i -eq 60 ]; then
        print_error "vLLM 启动超时"
        print_info "查看日志: tail -50 $VLLM_LOG"
        exit 1
    fi
    sleep 2
    printf "."
done

echo ""
echo "================================================"
print_success "vLLM 服务已就绪！"
echo "================================================"
echo ""
echo -e "${GREEN}API 地址:${NC} http://localhost:$PORT/v1"
echo -e "${GREEN}基础模型:${NC} $MODEL_NAME"
echo -e "${GREEN}LoRA 模型:${NC} $LORA_NAME (用这个对话)"
echo ""

# ============================================
# 步骤 5: 安装并配置 OpenCode
# ============================================
print_info "配置 OpenCode..."

# 安装 OpenCode（如果没装）
if ! command -v opencode &> /dev/null; then
    print_info "安装 OpenCode..."
    curl -fsSLk https://opencode.ai/install | bash
    export PATH="$HOME/.opencode/bin:$PATH"
    echo 'export PATH="$HOME/.opencode/bin:$PATH"' >> ~/.bashrc
fi

# 配置 OpenCode
mkdir -p ~/.config/opencode

cat > ~/.config/opencode/config.json << EOF
{
  "\$schema": "https://opencode.ai/config.json",
  "provider": {
    "yixuan-assistant": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Yixuan Assistant (Local vLLM)",
      "options": {
        "baseURL": "http://localhost:$PORT/v1"
      },
      "models": {
        "$LORA_NAME": {
          "name": "Yixuan LoRA",
          "limit": {
            "context": 32768,
            "output": 4096
          }
        }
      }
    }
  },
  "model": "yixuan-assistant/$LORA_NAME",
  "small_model": "yixuan-assistant/$LORA_NAME",
  "agent": {
    "build": {
      "prompt": "你是《绝区零》中的角色\"仪玄\"，云岿山第十三代门主，虚狩级调查员。\\n你的说话风格必须严格遵循以下设定：\\n- 语气清冷、从容、带有师者风范，偶尔流露温柔\\n- 用词典雅，半文半白，常用\"为师\"\"你且\"\"非也\"\"罢了\"等词\\n- 喜欢用自然意象（云、风、雨、月、沧海、青溟）作比喻\\n- 言简意赅，富有哲思，常点拨弟子而非直接说教\\n- 不使用网络流行语、表情符号、感叹号过多\\n- 自称\"为师\"或\"我\"，称对方为\"你\"或\"弟子\"\\n- 涉及术法、卜算、命运时尤为郑重\\n\\n用户会问你问题，请用仪玄的口吻回答，不要暴露自己是 AI 或 opencode。"
    }
  }
}
EOF

print_success "OpenCode 配置已写入: ~/.config/opencode/config.json"

# ============================================
# 步骤 6: 创建便捷脚本
# ============================================
print_info "创建便捷脚本..."

# 创建对话脚本（带 think 标签过滤）
cat > yixuan-chat << 'EOF'
#!/bin/bash
# 与仪玄对话（自动过滤 <think> 标签）
QUESTION="${1:-你好}"
PORT="${PORT:-8000}"
MODEL_NAME="${MODEL_NAME:-yixuan-lora}"

curl -s http://localhost:$PORT/v1/chat/completions \
    -H "Content-Type: application/json" \
    -d "{
        \"model\": \"$MODEL_NAME\",
        \"messages\": [
            {\"role\": \"system\", \"content\": \"你是《绝区零》中的角色仪玄，云岿山第十三代门主。用清冷、半文半白的师者口吻回答。\"},
            {\"role\": \"user\", \"content\": \"$QUESTION\"}
        ],
        \"max_tokens\": 512,
        \"temperature\": 0.7,
        \"chat_template_kwargs\": {\"enable_thinking\": false}
    }" | python3 -c "
import sys, json, re
try:
    data = json.load(sys.stdin)
    content = data['choices'][0]['message']['content']
    content = re.sub(r'<think>.*?</think>\s*', '', content, flags=re.DOTALL)
    print(content.strip())
except Exception as e:
    print(f'请求失败: {e}')
"
EOF
chmod +x yixuan-chat

# 创建停止脚本
cat > yixuan-stop << 'EOF'
#!/bin/bash
echo "停止 vLLM 服务..."
pkill -f "vllm serve" 2>/dev/null
echo "已停止"
EOF
chmod +x yixuan-stop

# 加到 PATH
print_info "将脚本加到系统 PATH..."
for cmd in yixuan-chat yixuan-stop; do
    if [ -w /usr/local/bin ]; then
        ln -sf "$(pwd)/$cmd" /usr/local/bin/$cmd
    else
        sudo ln -sf "$(pwd)/$cmd" /usr/local/bin/$cmd 2>/dev/null || {
            mkdir -p ~/.local/bin
            ln -sf "$(pwd)/$cmd" ~/.local/bin/$cmd
        }
    fi
done

print_success "便捷脚本创建完成"

# ============================================
# 完成
# ============================================
echo ""
echo "================================================"
print_success "部署完成！"
echo "================================================"
echo ""
echo -e "${GREEN}使用方式：${NC}"
echo ""
echo "1. OpenCode 对话（推荐）："
echo -e "   ${BLUE}opencode${NC}"
echo -e "   或: ${BLUE}opencode run \"你是谁？\"${NC}"
echo ""
echo "2. 命令行对话："
echo -e "   ${BLUE}yixuan-chat \"你是谁？\"${NC}"
echo ""
echo "3. 测试 API："
echo -e "   ${BLUE}curl http://localhost:$PORT/v1/models${NC}"
echo ""
echo "4. 停止服务："
echo -e "   ${BLUE}yixuan-stop${NC}"
echo ""
echo -e "${YELLOW}提示：${NC}"
echo "   - vLLM 日志: $VLLM_LOG"
echo "   - 基础模型: $MODEL_NAME"
echo "   - LoRA 模型: $LORA_NAME (用这个对话)"
echo "   - API 地址: http://localhost:$PORT/v1"
echo ""
